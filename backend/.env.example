# Configuration du backend Django — TESSIPI Foundation
# Copier ce fichier en .env et renseigner les valeurs.

# Django
DJANGO_SECRET_KEY=changez-moi-en-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=tessipi_foundation
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# CORS — origines autorisées (frontend React / Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email — notifications des formulaires vers l'adresse de la fondation.
# En dev, laisser EMAIL_BACKEND vide => backend « console » (emails affichés
# dans le terminal, aucun SMTP requis). En prod, renseigner le SMTP ci-dessous.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=TESSIPI Foundation <contact@tessipi.org>
CONTACT_EMAIL=contact@tessipi.org
